# Auto-generated by scripts/gen-screen-tapes.sh. Re-run the script to refresh.
Output tapes/out/screens/issuers.gif

Require vhs
Set Shell "bash"
Set Width 1280
Set Height 720
Set FontSize 14
Set Theme "Catppuccin Mocha"

Hide
Type "make tui-snap >/dev/null 2>&1"
Enter
Show

Type "clear; bin/tui-snap -view issuers -seed scripts/tui-snap-seeds/issuers.json"
Enter
Sleep 1500ms
